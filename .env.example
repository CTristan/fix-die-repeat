# fix-die-repeat Configuration Example
# Copy this file to .env and customize as needed

# Check command to run
FDR_CHECK_CMD=./scripts/ci.sh

# Maximum loop iterations
FDR_MAX_ITERS=10

# Override model selection (e.g., anthropic/claude-sonnet-4-5)
# FDR_MODEL=anthropic/claude-sonnet-4-5

# Maximum PR threads to process per iteration
FDR_MAX_PR_THREADS=5

# Archive existing artifacts to a timestamped folder
FDR_ARCHIVE_ARTIFACTS=0

# Automatically compact large artifacts
FDR_COMPACT_ARTIFACTS=1

# Enable PR review mode
FDR_PR_REVIEW=0

# Enable debug mode
FDR_DEBUG=0

# Enable ntfy notifications
FDR_NTFY_ENABLED=1

# ntfy server URL
FDR_NTFY_URL=http://localhost:2586

# Enable Zulip notifications
# FDR_ZULIP_ENABLED=0

# Zulip server base URL (required if enabled)
# FDR_ZULIP_SERVER_URL=https://your-zulip-server.example.com

# Zulip bot email for authentication (required if enabled)
# FDR_ZULIP_BOT_EMAIL=your-bot@example.com

# Zulip bot API key for authentication (required if enabled)
# FDR_ZULIP_BOT_API_KEY=your-api-key-here

# Zulip stream name (optional, defaults to "fix-die-repeat")
# FDR_ZULIP_STREAM=fix-die-repeat
